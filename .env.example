# Environment Configuration Example
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G_your_measurement_id

# OpenAI API (Optional - for AI features)
VITE_OPENAI_API_KEY=sk_your_openai_api_key_here

# Google APIs (Optional)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key
VITE_GOOGLE_ANALYTICS_ID=G_your_analytics_id

# SMTP Email Configuration (Optional)
VITE_SMTP_HOST=smtp.gmail.com
VITE_SMTP_PORT=587
VITE_SMTP_USER=your_email@gmail.com
VITE_SMTP_PASSWORD=your_app_password_here
VITE_SMTP_FROM=noreply@yourdomain.com

# Application
VITE_APP_NAME=Wedding Invitation Builder
VITE_APP_URL=https://yourdomain.com
NODE_ENV=production
